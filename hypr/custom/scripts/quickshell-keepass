#!/usr/bin/env bash
set -euo pipefail

VAULT_PATH="${KP_VAULT_PATH:-$HOME/Nextcloud/secrets/end4dot-keepass.kdbx}"
CACHE_TTL="${KP_CACHE_TTL:-300}"
NONINTERACTIVE="${KP_NONINTERACTIVE:-0}"
RUNTIME_DIR="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}"
CACHE_FILE="$RUNTIME_DIR/quickshell-keepass.pass"
STAMP_FILE="$RUNTIME_DIR/quickshell-keepass.stamp"

die() {
  echo "quickshell-keepass: $*" >&2
  exit 1
}

now_epoch() {
  date +%s
}

cache_valid() {
  [[ -f "$CACHE_FILE" && -f "$STAMP_FILE" ]] || return 1
  local now ts
  now="$(now_epoch)"
  ts="$(cat "$STAMP_FILE" 2>/dev/null || echo 0)"
  [[ "$ts" =~ ^[0-9]+$ ]] || return 1
  (( now - ts < CACHE_TTL ))
}

write_cache() {
  local password="$1"
  umask 077
  printf '%s' "$password" > "$CACHE_FILE"
  printf '%s' "$(now_epoch)" > "$STAMP_FILE"
}

touch_cache() {
  [[ -f "$STAMP_FILE" ]] || return 0
  printf '%s' "$(now_epoch)" > "$STAMP_FILE"
}

read_password() {
  if cache_valid; then
    cat "$CACHE_FILE"
    touch_cache
    return 0
  fi
  local password
  if [[ "$NONINTERACTIVE" == "1" || ! -t 0 ]]; then
    IFS= read -r password || die "locked (no cached password)"
    [[ -n "$password" ]] || die "locked (empty password)"
  else
    read -r -s -p "Vault password: " password
    echo >&2
    [[ -n "$password" ]] || die "empty password"
  fi
  write_cache "$password"
  printf '%s' "$password"
}

require_vault() {
  [[ -f "$VAULT_PATH" ]] || die "vault not found: $VAULT_PATH (run: quickshell-keepass init)"
}

cmd_init() {
  [[ -f "$VAULT_PATH" ]] && die "vault already exists: $VAULT_PATH"
  mkdir -p "$(dirname "$VAULT_PATH")"
  local password
  read -r -s -p "New vault password: " password
  echo >&2
  [[ -n "$password" ]] || die "empty password"
  printf '%s\n%s\n' "$password" "$password" | keepassxc-cli db-create -q -p "$VAULT_PATH"
  write_cache "$password"
  echo "Created vault: $VAULT_PATH"
}

cmd_lock() {
  if command -v shred >/dev/null 2>&1; then
    shred -u "$CACHE_FILE" "$STAMP_FILE" 2>/dev/null || true
  else
    rm -f "$CACHE_FILE" "$STAMP_FILE"
  fi
  echo "Locked (cache cleared)."
}

cmd_unlock() {
  local password
  if [[ "$NONINTERACTIVE" == "1" || ! -t 0 ]]; then
    IFS= read -r password || die "missing password"
  else
    read -r -s -p "Vault password: " password
    echo >&2
  fi
  [[ -n "$password" ]] || die "empty password"
  if printf '%s\n' "$password" | keepassxc-cli ls -q -R -f "$VAULT_PATH" >/dev/null 2>&1; then
    write_cache "$password"
    echo "Unlocked (cache set)."
  else
    die "invalid password"
  fi
}

cmd_status() {
  if cache_valid; then
    echo "unlocked (cache valid for ${CACHE_TTL}s)"
  else
    echo "locked"
  fi
}

kp() {
  local password cmd
  password="$(read_password)"
  cmd="${1:-}"
  shift || true
  printf '%s\n' "$password" | keepassxc-cli "$cmd" -q "$VAULT_PATH" "$@"
}

cmd_open() {
  require_vault
  kp open
}

cmd_search() {
  require_vault
  [[ $# -ge 1 ]] || die "usage: search <query>"
  kp search "$@"
}

cmd_ls() {
  require_vault
  kp ls "$@"
}

cmd_show() {
  require_vault
  [[ $# -ge 1 ]] || die "usage: show <entry> [attributes...]"
  kp show "$@"
}

cmd_get() {
  require_vault
  [[ $# -ge 2 ]] || die "usage: get <entry> <attribute>"
  kp show -s -a "$2" "$1"
}

cmd_clip() {
  require_vault
  [[ $# -ge 2 ]] || die "usage: clip <entry> <attribute>"
  kp clip -a "$2" "$1"
}

cmd_copy_private() {
  require_vault
  [[ $# -ge 2 ]] || die "usage: copy-private <entry> <attribute>"
  local entry="$1"
  local attr="$2"
  local value
  value="$(kp show -s -a "$attr" "$entry" | sed -n '1p')"
  [[ -n "$value" ]] || die "empty value"
  if command -v wl-copy >/dev/null 2>&1; then
    printf '%s' "$value" | wl-copy --type text
  elif command -v xclip >/dev/null 2>&1; then
    printf '%s' "$value" | xclip -selection clipboard
  else
    die "no clipboard tool (wl-copy/xclip)"
  fi
  # Remove the last cliphist entry to keep clipboard private
  if command -v cliphist >/dev/null 2>&1; then
    sleep 0.1
    local last
    last="$(cliphist list | head -n 1)"
    if [[ -n "$last" ]]; then
      printf '%s' "$last" | cliphist delete >/dev/null 2>&1 || true
    fi
  fi
}

cmd_add() {
  require_vault
  [[ $# -ge 1 ]] || die "usage: add <entry> [username] [url]"
  local entry="$1"
  local username="${2:-}"
  local url="${3:-}"

  # db password first: from cache, or line 1 of stdin in non-interactive mode
  local db_password
  db_password="$(read_password)"

  # entry password: line 2 of stdin (or next line if cache was used), or KP_ENTRY_PASSWORD env
  local entry_password="${KP_ENTRY_PASSWORD:-}"
  if [[ -z "$entry_password" ]]; then
    if [[ "$NONINTERACTIVE" == "1" || ! -t 0 ]]; then
      IFS= read -r entry_password || die "missing entry password"
    else
      read -r -s -p "Entry password: " entry_password
      echo >&2
    fi
  fi
  [[ -n "$entry_password" ]] || die "empty entry password"

  local group="${entry%/*}"
  if [[ "$group" != "$entry" && -n "$group" && "$group" != "/" ]]; then
    printf '%s\n' "$db_password" | keepassxc-cli mkdir -q "$VAULT_PATH" "$group" >/dev/null 2>&1 || true
  fi

  local args=("add" "-q")
  [[ -n "$username" ]] && args+=("-u" "$username")
  [[ -n "$url" ]] && args+=("--url" "$url")
  args+=("--password-prompt" "$VAULT_PATH" "$entry")

  printf '%s\n%s\n' "$db_password" "$entry_password" | keepassxc-cli "${args[@]}"
}

_KP_WORDS_IT=(
  gatto cane topo coniglio riccio pipistrello cigno merlo picchio rana
  lumaca formica vespa farfalla serpente lucertola tartaruga volpe lepre
  pane formaggio burro miele pasta pizza uovo salame prosciutto mozzarella
  basilico rosmarino cannella cioccolata biscotto torta gelato caffè birra
  pomello piastrella balcone finestra tenda lampada sedia tavolo cuscino
  secchio spazzola setaccio imbuto colapasta mestolo spatola mattarello
  teglia pentola padella coperchio cavatappi forbici righello compasso
  albero fiore foglia ramo tronco muschio felce prato bosco collina
  montagna valle fiume lago ruscello cascata roccia ciottolo sabbia
  scarpa stivale sandalo cappello guanto cintura borsa zaino ombrello
  maglione giacca camicia gonna calzino sciarpa cravatta impermeabile
  cantina soffitta garage corridoio scalinata marciapiede semaforo vicolo
  portico terrazza campanile stazione mercato biblioteca palestra
  chiave lucchetto maniglia bullone vite grondaia tegola mattone
  telefono tastiera schermo cavo antenna segnale motore ruota pedivella
  treno autobus bicicletta moto elicottero nave sottomarino mongolfiera
  pioggia neve vento sole luna stella nuvola arcobaleno fulmine nebbia
  pomodoro patata carota cipolla aglio peperone melanzana zucca
  mela pera arancia limone uva fragola ciliegia pesca banana melograno
)

_kp_rand_u16() {
  od -An -tu2 -N2 /dev/urandom | tr -d ' \n'
}

_kp_rand_u8() {
  od -An -tu1 -N1 /dev/urandom | tr -d ' \n'
}

cmd_generate_words() {
  local length="${KP_GEN_LENGTH:-20}"
  local word_count=3
  (( length <= 8 ))  && word_count=2
  (( length >= 20 )) && word_count=4

  local pool_size=${#_KP_WORDS_IT[@]}

  # Pick unique words
  local -a chosen=()
  local -a used=()
  while (( ${#chosen[@]} < word_count )); do
    local idx
    idx=$(( $(_kp_rand_u16) % pool_size ))
    local dup=0
    for u in "${used[@]:-}"; do [[ "$u" == "$idx" ]] && dup=1 && break; done
    (( dup )) && continue
    used+=("$idx")
    chosen+=("${_KP_WORDS_IT[$idx]}")
  done

  # Ogni parola: casualmente tutta maiuscola o tutta minuscola
  local -a styled=()
  for word in "${chosen[@]}"; do
    if (( $(_kp_rand_u8) % 2 )); then
      styled+=("${word^^}")
    else
      styled+=("$word")
    fi
  done

  # Slot simbolo: 0..word_count (random), 0=prima di tutto, n=dopo n-esima parola
  local sym_slot=-1
  if [[ "${KP_GEN_SYMBOLS:-1}" == "1" ]]; then
    local symbols='!@#$%^&*'
    sym_slot=$(( $(_kp_rand_u8) % (word_count + 1) ))
  fi

  local result=""
  local sym_char=""
  if (( sym_slot >= 0 )); then
    local sidx=$(( $(_kp_rand_u8) % ${#symbols} ))
    sym_char="${symbols:$sidx:1}"
  fi

  for ((i=0; i<word_count; i++)); do
    (( i == sym_slot )) && result+="$sym_char"
    result+="${styled[$i]}"
    if [[ "${KP_GEN_NUMBERS:-1}" == "1" && $i -lt $((word_count - 1)) ]]; then
      result+=$(( ($(_kp_rand_u8) % 99) + 1 ))
    fi
  done
  (( sym_slot == word_count )) && result+="$sym_char"

  printf '%s\n' "$result"
}

cmd_generate() {
  if [[ "${KP_GEN_WORDS:-0}" == "1" ]]; then
    cmd_generate_words
    return
  fi
  local length="${KP_GEN_LENGTH:-20}"
  local chars='abcdefghijklmnopqrstuvwxyz'
  [[ "${KP_GEN_UPPER:-1}"   == "1" ]] && chars+='ABCDEFGHIJKLMNOPQRSTUVWXYZ'
  [[ "${KP_GEN_NUMBERS:-1}" == "1" ]] && chars+='0123456789'
  [[ "${KP_GEN_SYMBOLS:-1}" == "1" ]] && chars+='!@#$%^&*()_=+[]{}|;:,.?-'
  LC_ALL=C tr -dc "$chars" < /dev/urandom | head -c "$length"
  printf '\n'
}

cmd_help() {
  cat <<'EOF'
quickshell-keepass

Usage:
  quickshell-keepass init
  quickshell-keepass status
  quickshell-keepass lock
  quickshell-keepass open
  quickshell-keepass search <query>
  quickshell-keepass ls [group]
  quickshell-keepass show <entry> [attributes...]
  quickshell-keepass get <entry> <attribute>
  quickshell-keepass clip <entry> <attribute>
  quickshell-keepass copy-private <entry> <attribute>
  quickshell-keepass add <entry> [username] [url]

Env:
  KP_VAULT_PATH     Vault path (default: ~/Nextcloud/secrets/end4dot-keepass.kdbx)
  KP_CACHE_TTL      Cache TTL in seconds (default: 300)
  KP_ENTRY_PASSWORD Provide entry password for 'add' non-interactively
  KP_NONINTERACTIVE Set to 1 to disable prompts (password read from stdin)

Note: vault password is always read from stdin when non-interactive.
EOF
}

main() {
  local cmd="${1:-help}"
  shift || true
  case "$cmd" in
    init) cmd_init "$@" ;;
    status) cmd_status ;;
    lock) cmd_lock ;;
    unlock) cmd_unlock ;;
    open) cmd_open ;;
    search) cmd_search "$@" ;;
    ls) cmd_ls "$@" ;;
    show) cmd_show "$@" ;;
    get) cmd_get "$@" ;;
    clip) cmd_clip "$@" ;;
    copy-private) cmd_copy_private "$@" ;;
    add) cmd_add "$@" ;;
    generate) cmd_generate ;;
    help|-h|--help) cmd_help ;;
    *) die "unknown command: $cmd" ;;
  esac
}

main "$@"
